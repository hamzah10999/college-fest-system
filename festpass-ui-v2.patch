+            <Link href="/" className="flex items-center gap-2.5 mb-4 group">
+              <div className="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-indigo-600 to-violet-600 text-white transition-transform group-hover:scale-105">
+                <QrCode className="h-4 w-4" />
